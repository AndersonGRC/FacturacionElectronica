# FacturacionDIAN — plantilla de configuracion
# Copiar a .env y llenar valores reales. NUNCA commitear el .env.
FLASK_SECRET_KEY=
FLASK_ENV=production
DB_NAME=facturacion_dian
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
MASTER_API_KEY=
FERNET_KEY=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
STORAGE_BASE=/var/www/FacturacionDIAN/storage
DIAN_TIMEOUT=30
CERT_PRUEBA_PATH=
CERT_PRUEBA_PASSWORD=
CYBERSHOP_TENANT_ID=1
LOG_LEVEL=INFO
DELAY_DIAS=0
